# 复制为 .env 后按需填写。
# 该文件只放环境变量入口，不直接承载复杂 JSON / TOML 策略内容。

# -----------------------------------------------------------------------------
# 模型下载源配置（可选）
# -----------------------------------------------------------------------------
# 指向外部 model_sources.toml。未设置时，程序默认读取 examples/model_sources.toml。
# MODEL_SOURCES_PATH=/abs/path/to/model_sources.toml

# -----------------------------------------------------------------------------
# OpenAI / 兼容 OpenAI 的服务（可选）
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# Gemini（可选）
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=
# GEMINI_BASE_URL=

# -----------------------------------------------------------------------------
# 其他 API / OCR / 渲染相关变量（按需补充）
# -----------------------------------------------------------------------------
# 说明：更多环境变量与详细配置方式，请查看：
# - doc/API_CONFIG.md
# - doc/SETTINGS.md
# - doc/DEVELOPMENT.md
